# Exclude entire TypeScript directory (only inst/htmlwidgets/lib/app/ needed for R)
^visual-web-tool/.*$

# Development files
^\.vscode.*                   # Editor configs
^\.github.*                   # GitHub workflows (optional)
^\.gitignore
^Noise files/
^notes/.*
^\.eslintrc.*

# Git hooks (keep in git, but exclude from tarball if needed)
# ^\.githooks.*

# Note: DO NOT ignore inst/htmlwidgets/lib/app/ (widget assets needed for install_github)

^docs$

^.*\.Rproj$
^\.Rproj\.user$
