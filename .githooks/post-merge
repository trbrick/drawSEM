#!/bin/bash

# Check if web-tool source files changed in the merge
if git diff HEAD@{1} --name-only | grep -qE 'drawsem-web/'; then
    echo "Detected web tool changes after merge. Rebuilding widget..."
    
    cd drawsem-web
    npm run build:widget
    cd ..
    
    echo "Widget rebuilt"
fi

exit 0
